{
  "name": "bevy-common-systems-showcase",
  "version": "1.0.0",
  "description": "Playable WebAssembly builds of the bevy_common_systems example games.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:games": "bash scripts/build-games.sh",
    "build:web": "webpack --config webpack.config.js",
    "build": "npm run build:games && npm run build:web",
    "serve": "webpack serve --config webpack.config.js",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" *.js *.json",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" *.js *.json",
    "lint": "eslint \"src/**/*.ts\"",
    "ci": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.15.0",
    "html-webpack-plugin": "^5.6.3",
    "prettier": "^3.4.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
